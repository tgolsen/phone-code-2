#!/usr/bin/env bash
set -e

trap 'echo "FATAL: command failed at line $LINENO" >&2' ERR

# Check required tools
for cmd in curl ssh-keygen; do
    if ! command -v "$cmd" >/dev/null 2>&1; then
        echo "Error: '$cmd' is required but not installed."
        echo "Install on Termux: pkg install curl openssh"
        echo "Install on iSH:    apk add curl openssh"
        exit 1
    fi
done

usage() {
    echo "Usage: $0 <project-name>     Start or reconnect to a session"
    echo "       $0 --stop [task-arn]   Stop current session"
    echo "       $0 --help              Show this message"
    echo ""
    echo "Example: $0 my-awesome-project"
    echo ""
    echo "Config: ~/.phone-code-config (see config.example)"
    exit "${1:-1}"
}

PHONE_CODE_DIR="${HOME}/.phone-code"

PROJECT="$1"

if [ "$1" = "--help" ] || [ "$1" = "-h" ]; then
    usage 0
fi

if [ "$1" = "--stop" ]; then
    CONFIG_FILE="${PHONE_CODE_CONFIG:-$HOME/.phone-code-config}"
    [ -f "$CONFIG_FILE" ] && source "$CONFIG_FILE"
    API_URL="${PHONE_CODE_API_URL:?PHONE_CODE_API_URL not set}"
    API_KEY="${PHONE_CODE_API_KEY:?PHONE_CODE_API_KEY not set}"

    TASK_ID="$2"
    if [ -z "$TASK_ID" ]; then
        TASK_ID=$(cat $PHONE_CODE_DIR/task 2>/dev/null || echo '')
    fi
    if [ -z "$TASK_ID" ]; then
        echo "Usage: $0 --stop <task-arn>"
        echo "Or run after starting a session (reads $PHONE_CODE_DIR/task)"
        exit 1
    fi
    ENCODED=$(echo "$TASK_ID" | sed 's/:/%3A/g;s/\//%2F/g')
    echo "Stopping session: $TASK_ID"
    curl -s -X DELETE "$API_URL/sessions?taskId=$ENCODED" -H "X-API-Key: $API_KEY"
    rm -f $PHONE_CODE_DIR/task $PHONE_CODE_DIR/key $PHONE_CODE_DIR/key.pub $PHONE_CODE_DIR/project
    echo "Session stopped."
    exit 0
fi

if [ -z "$PROJECT" ]; then
    usage
fi

echo "Phone Code"
echo "=========="

# Load config
CONFIG_FILE="${PHONE_CODE_CONFIG:-$HOME/.phone-code-config}"
if [ -f "$CONFIG_FILE" ]; then
    source "$CONFIG_FILE"
fi

API_URL="${PHONE_CODE_API_URL:?PHONE_CODE_API_URL not set — see config.example}"
API_KEY="${PHONE_CODE_API_KEY:?PHONE_CODE_API_KEY not set — see config.example}"
GITHUB_USER="${GITHUB_USER:-$(git config --global user.name || echo '')}"
GITHUB_TOKEN="${GITHUB_TOKEN:-}"

mkdir -p "$PHONE_CODE_DIR"
chmod 700 "$PHONE_CODE_DIR"

# ── Helpers (no jq dependency) ───────────────────────────────

# Extract a string value from simple flat JSON: json_val "$json" "key"
json_val() {
    echo "$1" | grep -o "\"$2\"[[:space:]]*:[[:space:]]*\"[^\"]*\"" | head -1 | sed 's/.*: *"//;s/"$//'
}

# URL-encode an ECS task ARN (only : and / need encoding)
urlencode() {
    echo "$1" | sed 's/:/%3A/g;s/\//%2F/g'
}

# Test if a TCP port is open (bash builtin /dev/tcp)
tcp_ready() {
    timeout 3 bash -c "echo >/dev/tcp/\$1/\$2" _ "$1" "$2" 2>/dev/null
}

# ── Check for existing session to reconnect ──────────────────

SAVED_TASK=$(cat $PHONE_CODE_DIR/task 2>/dev/null || echo '')
SAVED_KEY=$PHONE_CODE_DIR/key
RECONNECT=0

if [ -n "$SAVED_TASK" ] && [ -f "$SAVED_KEY" ]; then
    ENCODED=$(urlencode "$SAVED_TASK")

    set +e
    CHECK=$(curl -s "$API_URL/sessions?taskId=$ENCODED" -H "X-API-Key: $API_KEY" 2>/dev/null || echo '{}')
    set -e

    STATUS=$(json_val "$CHECK" "status")
    HOST=$(json_val "$CHECK" "host")

    if [ "$STATUS" = "RUNNING" ] && [ -n "$HOST" ] && [ "$HOST" != "pending" ] && [ "$HOST" != "resolving" ] && ! echo "$HOST" | grep -qE '^(10\.|172\.(1[6-9]|2[0-9]|3[0-1])\.|192\.168\.)'; then
        echo "Existing session found: $SAVED_TASK"
        echo "Reconnecting to $HOST..."
        RECONNECT=1
    else
        rm -f $PHONE_CODE_DIR/task $PHONE_CODE_DIR/key $PHONE_CODE_DIR/key.pub $PHONE_CODE_DIR/project
    fi
fi

# ── New session (if no reconnect) ────────────────────────────

if [ "$RECONNECT" -eq 0 ]; then
    echo "Generating SSH key..."
    rm -f $SAVED_KEY $SAVED_KEY.pub
    ssh-keygen -t ed25519 -f $SAVED_KEY -N "" -C "phone-code-session" -q
    PUBKEY=$(cat $SAVED_KEY.pub)
    echo "Key generated."

    echo "Requesting session..."
    BODY="{\"project\":\"$PROJECT\",\"pubkey\":\"$PUBKEY\",\"github_user\":\"$GITHUB_USER\",\"github_token\":\"$GITHUB_TOKEN\"}"

    set +e
    HTTP_RESPONSE=$(curl -s -w "\n%{http_code}" -X POST "$API_URL/sessions" \
        -H "Content-Type: application/json" \
        -H "X-API-Key: $API_KEY" \
        --connect-timeout 10 \
        -d "$BODY" 2>&1)
    CURL_EXIT=$?
    set -e

    if [ $CURL_EXIT -ne 0 ]; then
        echo "Error: could not reach $API_URL (curl exit $CURL_EXIT)"
        echo "$HTTP_RESPONSE"
        exit 1
    fi

    HTTP_CODE=$(echo "$HTTP_RESPONSE" | tail -1)
    RESPONSE_BODY=$(echo "$HTTP_RESPONSE" | sed '$d')

    if [ "$HTTP_CODE" != "202" ]; then
        echo "API returned HTTP $HTTP_CODE:"
        echo "$RESPONSE_BODY"
        exit 1
    fi

    echo "$RESPONSE_BODY"

    HOST=$(json_val "$RESPONSE_BODY" "host")
    TASK_ARN=$(json_val "$RESPONSE_BODY" "task_arn")
    ERROR=$(json_val "$RESPONSE_BODY" "error")

    if [ -n "$ERROR" ]; then
        echo "Error: $ERROR"
        exit 1
    fi

    echo "$TASK_ARN" > $PHONE_CODE_DIR/task
    echo "$PROJECT" > $PHONE_CODE_DIR/project

    echo "Waiting for container to start..."
    ENCODED_ARN=$(urlencode "$TASK_ARN")
    MAX_WAIT=30
    for i in $(seq 1 $MAX_WAIT); do
        sleep 3
        CHECK=$(curl -s "$API_URL/sessions?taskId=$ENCODED_ARN" -H "X-API-Key: $API_KEY" 2>/dev/null || echo '{}')
        HOST=$(json_val "$CHECK" "host")
        STATUS=$(json_val "$CHECK" "status")

        if [ "$STATUS" = "RUNNING" ] && [ -n "$HOST" ] && [ "$HOST" != "pending" ] && [ "$HOST" != "resolving" ]; then
            if echo "$HOST" | grep -qE '^(10\.|172\.(1[6-9]|2[0-9]|3[0-1])\.|192\.168\.)'; then
                echo "  Private IP (waiting for public)..."
                continue
            fi
            echo "  Ready: $HOST"
            break
        fi
        echo "  $((i * 3))s: $STATUS"
    done

    if [ "$HOST" = "pending" ] || [ "$HOST" = "resolving" ] || [ -z "$HOST" ]; then
        echo "Failed to resolve container IP. Task: $TASK_ARN"
        exit 1
    fi

    echo "Waiting for SSH on $HOST:2222..."
    SSH_READY=0
    for i in $(seq 1 25); do
        if tcp_ready "$HOST" 2222; then
            echo "  SSH ready after $((i * 3))s"
            SSH_READY=1
            break
        fi
        sleep 3
    done

    if [ "$SSH_READY" -eq 0 ]; then
        echo "Warning: SSH port not responding, but attempting connection anyway..."
    fi

    echo ""
    echo "Connecting to $PROJECT on $HOST..."
    echo "Sessions stays alive 15 min after disconnect. Reconnect: $0 $PROJECT"
    echo "Type 'exit' or Ctrl+D when done."
    echo ""
else
    echo ""
    echo "Session stays alive 15 min after disconnect. Reconnect: $0 $PROJECT"
    echo ""
fi

# SSH into the container
ssh -t -i $SAVED_KEY -p 2222 -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -o ConnectTimeout=10 -o IdentitiesOnly=yes -o PasswordAuthentication=no phonecoder@"$HOST" || true

# Session kept alive — do NOT call DELETE
echo ""
echo "Session still running (auto-stop after 15 min idle)."
echo "Reconnect: $0 $PROJECT"
echo "Force stop: $0 --stop"
