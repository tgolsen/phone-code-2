#!/bin/bash
set -e

usage() {
    echo "Usage: $0 <project-name>     Start a coding session"
    echo "       $0 --stop [task-arn]   Stop current session"
    echo "       $0 --help              Show this message"
    echo ""
    echo "Example: $0 my-awesome-project"
    echo ""
    echo "Config: ~/.phone-code-config (see config.example)"
    exit "${1:-1}"
}

PHONE_CODE_DIR="${HOME}/.phone-code"

PROJECT="$1"

if [ "$1" = "--help" ] || [ "$1" = "-h" ]; then
    usage 0
fi

if [ "$1" = "--stop" ]; then
    # Load config early for --stop
    CONFIG_FILE="${PHONE_CODE_CONFIG:-$HOME/.phone-code-config}"
    [ -f "$CONFIG_FILE" ] && source "$CONFIG_FILE"
    API_URL="${PHONE_CODE_API_URL:?PHONE_CODE_API_URL not set}"
    API_KEY="${PHONE_CODE_API_KEY:?PHONE_CODE_API_KEY not set}"

    TASK_ID="$2"
    if [ -z "$TASK_ID" ]; then
        # Try reading from state file
        TASK_ID=$(cat $PHONE_CODE_DIR/task 2>/dev/null || echo '')
    fi
    if [ -z "$TASK_ID" ]; then
        echo "Usage: $0 --stop <task-arn>"
        echo "Or run after starting a session (reads $PHONE_CODE_DIR/task)"
        exit 1
    fi
    ENCODED=$(python3 -c "import urllib.parse; print(urllib.parse.quote('$TASK_ID', safe=''))" 2>/dev/null || echo "$TASK_ID")
    echo "Stopping session: $TASK_ID"
    curl -s -X DELETE "$API_URL/sessions?taskId=$ENCODED" -H "X-API-Key: $API_KEY"
    rm -f $PHONE_CODE_DIR/task $PHONE_CODE_DIR/key $PHONE_CODE_DIR/key.pub
    echo "Session stopped."
    exit 0
fi

if [ -z "$PROJECT" ]; then
    usage
fi

echo "Phone Code"
echo "=========="

# Load config
CONFIG_FILE="${PHONE_CODE_CONFIG:-$HOME/.phone-code-config}"
if [ -f "$CONFIG_FILE" ]; then
    source "$CONFIG_FILE"
fi

API_URL="${PHONE_CODE_API_URL:?PHONE_CODE_API_URL not set — see config.example}"
API_KEY="${PHONE_CODE_API_KEY:?PHONE_CODE_API_KEY not set — see config.example}"
GITHUB_USER="${GITHUB_USER:-$(git config --global user.name || echo '')}"
GITHUB_TOKEN="${GITHUB_TOKEN:-}"

mkdir -p "$PHONE_CODE_DIR"
chmod 700 "$PHONE_CODE_DIR"

# Generate ephemeral SSH key
echo "Generating SSH key..."
rm -f $PHONE_CODE_DIR/key $PHONE_CODE_DIR/key.pub
ssh-keygen -t ed25519 -f $PHONE_CODE_DIR/key -N "" -C "phone-code-session" -q
PUBKEY=$(cat $PHONE_CODE_DIR/key.pub)
echo "Key generated."

# Request session from Lambda
echo "Requesting session..."
RESPONSE=$(curl -s -X POST "$API_URL/sessions" \
    -H "Content-Type: application/json" \
    -H "X-API-Key: $API_KEY" \
    -d "$(jq -nc \
        --arg project "$PROJECT" \
        --arg pubkey "$PUBKEY" \
        --arg github_user "$GITHUB_USER" \
        --arg github_token "$GITHUB_TOKEN" \
        '{project: $project, pubkey: $pubkey, github_user: $github_user, github_token: $github_token}')")

echo "$RESPONSE" | jq .

HOST=$(echo "$RESPONSE" | jq -r '.host // empty')
TASK_ARN=$(echo "$RESPONSE" | jq -r '.task_arn // empty')
ERROR=$(echo "$RESPONSE" | jq -r '.error // empty')

if [ -n "$ERROR" ]; then
    echo "Error: $ERROR"
    exit 1
fi

echo "Waiting for container to start..."
ENCODED_ARN=$(python3 -c "import urllib.parse; print(urllib.parse.quote('$TASK_ARN', safe=''))" 2>/dev/null || echo "$TASK_ARN")
MAX_WAIT=30
for i in $(seq 1 $MAX_WAIT); do
    sleep 3
    CHECK=$(curl -s "$API_URL/sessions?taskId=$ENCODED_ARN" -H "X-API-Key: $API_KEY" 2>/dev/null || echo '{}')
    HOST=$(echo "$CHECK" | jq -r '.host // empty')
    STATUS=$(echo "$CHECK" | jq -r '.status // empty')

    if [ "$STATUS" = "RUNNING" ] && [ -n "$HOST" ] && [ "$HOST" != "pending" ] && [ "$HOST" != "resolving" ]; then
        if echo "$HOST" | grep -qE '^(10\.|172\.(1[6-9]|2[0-9]|3[0-1])\.|192\.168\.)'; then
            echo "  Private IP (waiting for public)..."
            continue
        fi
        echo "  Ready: $HOST"
        break
    fi
    echo "  $((i * 3))s: $STATUS"
done

if [ "$HOST" = "pending" ] || [ "$HOST" = "resolving" ] || [ -z "$HOST" ]; then
    echo "Failed to resolve container IP. Task: $TASK_ARN"
    echo "You can manually check: aws ecs describe-tasks --cluster phone-code --tasks $TASK_ARN"
    exit 1
fi

# Save task ARN for --stop
echo "$TASK_ARN" > $PHONE_CODE_DIR/task
ENCODED_ARN=$(python3 -c "import urllib.parse; print(urllib.parse.quote('$TASK_ARN', safe=''))" 2>/dev/null || echo "$TASK_ARN")

# Wait for SSH to be ready
echo "Waiting for SSH on $HOST:2222..."
SSH_READY=0
for i in $(seq 1 25); do
    if nc -z -w 3 "$HOST" 2222 2>/dev/null; then
        echo "  SSH ready after $((i * 3))s"
        SSH_READY=1
        break
    fi
    sleep 3
done

if [ "$SSH_READY" -eq 0 ]; then
    echo "Warning: SSH port not responding, but attempting connection anyway..."
fi

echo ""
echo "Connecting to $PROJECT on $HOST..."
echo "Session branch will be created automatically."
echo "Type 'exit' or Ctrl+D when done."
echo ""

# SSH into the container (ignore connection errors so cleanup runs)
ssh -t -i $PHONE_CODE_DIR/key -p 2222 -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -o ConnectTimeout=10 -o IdentitiesOnly=yes -o PasswordAuthentication=no phonecoder@"$HOST" || true

# Cleanup on exit
echo ""
echo "Session ended. Cleaning up..."
curl -s -X DELETE "$API_URL/sessions?taskId=$ENCODED_ARN" -H "X-API-Key: $API_KEY" > /dev/null 2>&1 || true
rm -f $PHONE_CODE_DIR/task $PHONE_CODE_DIR/key $PHONE_CODE_DIR/key.pub
echo "Done."
